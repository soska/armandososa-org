---
import type { CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';
import { render } from 'astro:content';
import { resolveProjectImage } from '../lib/projectImages';

interface Props {
  projects: CollectionEntry<'projects'>[];
}

const { projects } = Astro.props;
const rendered = new Map(
  await Promise.all(
    projects.map(async (project) => [project.id, (await render(project)).Content] as const)
  )
);

// Only projects that have a resolvable image, in display order. Computed once and
// reused for both the thumbnail grid and the modals so they stay in sync.
const visibleProjects = projects
  .slice()
  .sort((a, b) => a.data.order - b.data.order)
  .filter((project) => resolveProjectImage(project.id, project.data.image) !== undefined);
---

<div class="wrapper flex flex-col gap-8 border-b-2 border-gray-800/10 pt-16 pb-24">
  <h2 class="relative font-grotesque text-4xl font-bold text-accent">Recent passion projects</h2>
  <div class="grid grid-cols-2 gap-6 md:grid-cols-3 lg:grid-cols-4">
    {
      visibleProjects.map((project, index) => {
        const image = resolveProjectImage(project.id, project.data.image)!;
        return (
          <a
            href={`#project-${project.id}`}
            class="block animate-fade-in motion-reduce:animate-none"
            aria-haspopup="dialog"
            aria-label={`Open details for ${project.data.title}`}
            style={{ animationDelay: `${index * 200}ms` }}
          >
            <Image
              src={image}
              alt={project.data.title}
              class="aspect-square w-full scale-100 overflow-hidden rounded-3xl border-0 border-white bg-white object-cover shadow-2xl transition-all duration-210 ease-in-out hover:scale-110 hover:border-4 hover:border-white"
              loading="lazy"
              fetchpriority="high"
              width={500}
              height={500}
              sizes="(min-width: 1024px) 13rem, (min-width: 768px) 30vw, 45vw"
              style={{ aspectRatio: '1 / 1' }}
            />
          </a>
        );
      })
    }
  </div>
</div>

{
  visibleProjects.map((project) => {
    const Description = rendered.get(project.id);
    const image = resolveProjectImage(project.id, project.data.image)!;
    return (
      <div
        id={`project-${project.id}`}
        class="group fixed inset-0 z-50 hidden items-center justify-center p-6 target:flex"
        role="dialog"
        aria-modal="true"
        aria-labelledby={`modal-title-${project.id}`}
      >
        <a
          href="#"
          class="absolute inset-0 bg-accent/60 backdrop-blur-xl"
          aria-label="Close"
          tabindex="-1"
        />
        <div class="relative z-1 max-h-[90vh] w-full max-w-2xl overflow-auto rounded-[1.25rem] bg-sand p-8 shadow-[0_25px_50px_-12px_rgba(0,0,0,0.45)] group-target:animate-fade-in-fast motion-reduce:animate-none">
          <a
            href="#"
            class="absolute top-3 right-4 text-[1.75rem] leading-none text-muted no-underline hover:text-accent focus-visible:text-accent"
            aria-label="Close"
            data-modal-close
          >
            ×
          </a>
          <div class="mb-5 overflow-hidden rounded-xl bg-line">
            <Image
              src={image}
              alt={project.data.title}
              class="block h-auto w-full object-cover"
              width={800}
              height={600}
            />
          </div>
          <h2 id={`modal-title-${project.id}`} class="mt-0 mb-4">
            {project.data.title}
          </h2>
          {Description && (
            <div class="[&_p:last-child]:mb-0">
              <Description />
            </div>
          )}
          <a
            href={project.data.url}
            class="mt-6 inline-block font-bold"
            target="_blank"
            rel="noopener noreferrer"
          >
            Visit site →
          </a>
        </div>
      </div>
    );
  })
}

<style>
  /* Lock background scroll while any modal is open. A `:has()` rule on `body`
     can't be expressed as a utility on the modal element, so it stays here. */
  :global(body:has([role='dialog']:target)) {
    overflow: hidden;
  }
</style>

<script>
  // Progressive enhancement: give the `:target` modals real dialog behavior when
  // JS is available (focus management, focus trap, Escape to close). None of the
  // basic open/close depends on this — that's handled by CSS `:target`.
  const FOCUSABLE =
    'a[href], button:not([disabled]), input, textarea, select, [tabindex]:not([tabindex="-1"])';

  let lastFocused: HTMLElement | null = null;

  function currentModal(): HTMLElement | null {
    const hash = location.hash.slice(1);
    if (!hash) return null;
    const el = document.getElementById(hash);
    return el && el.matches('[role="dialog"]') ? el : null;
  }

  function onHashChange() {
    const modal = currentModal();
    if (!modal) return;
    // Remember the thumbnail that opened this so we can restore focus on close.
    if (!(lastFocused && lastFocused.matches('[role="dialog"], [role="dialog"] *'))) {
      lastFocused = document.activeElement as HTMLElement | null;
    }
    const close = modal.querySelector<HTMLElement>('[data-modal-close]');
    close?.focus();
  }

  function closeModal() {
    const toFocus = lastFocused;
    lastFocused = null;
    // Navigating the hash to empty is what actually drops the `:target` (and hides
    // the modal via CSS) — `history.replaceState` alone does NOT re-evaluate
    // `:target`. Then tidy the leftover `#` out of the URL without a history entry.
    location.hash = '';
    history.replaceState(null, '', location.pathname + location.search);
    toFocus?.focus();
  }

  document.addEventListener('keydown', (event) => {
    const modal = currentModal();
    if (!modal) return;

    if (event.key === 'Escape') {
      event.preventDefault();
      closeModal();
      return;
    }

    if (event.key === 'Tab') {
      const focusables = Array.from(modal.querySelectorAll<HTMLElement>(FOCUSABLE)).filter(
        (el) => el.offsetParent !== null
      );
      if (focusables.length === 0) return;
      const first = focusables[0];
      const last = focusables[focusables.length - 1];
      const active = document.activeElement as HTMLElement | null;

      if (event.shiftKey && active === first) {
        event.preventDefault();
        last.focus();
      } else if (!event.shiftKey && active === last) {
        event.preventDefault();
        first.focus();
      } else if (active && !modal.contains(active)) {
        event.preventDefault();
        first.focus();
      }
    }
  });

  window.addEventListener('hashchange', onHashChange);
  // Handle a modal that's already targeted on initial load (e.g. deep link).
  onHashChange();
</script>
