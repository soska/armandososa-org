---
interface Props {
  href: string;
  label: string;
}

const { href, label } = Astro.props;
---

<a
  href={href}
  target="_blank"
  rel="noreferrer"
  class="transition-background-color flex items-center gap-2 rounded-sm bg-transparent px-3 py-3 text-white/75 hover:bg-black/10 hover:text-white"
>
  <span class="[&>svg]:size-6 lg:[&>svg]:size-4">
    <slot />
  </span>
  <span class="hidden md:block">
    {label}
  </span>
</a>
