---
import SpotifyIcon from './icons/SpotifyIcon.astro';
import AppleMusicIcon from './icons/AppleMusicIcon.astro';
import YouTubeIcon from './icons/YouTubeIcon.astro';

const artistLinks = {
  youtube: 'https://www.youtube.com/channel/UChLJSdV8ewJiF4QWhngXxBA',
  spotify: 'https://open.spotify.com/search/Inconforme%20Armando%20Sosa',
  apple: 'https://music.apple.com/us/search?term=Inconforme%20Armando%20Sosa',
};

const songs = [
  {
    title: 'Entera Consagración',
    url: 'https://www.youtube.com/watch?v=bjS2Von5Hj8',
    videoId: 'bjS2Von5Hj8',
    apple: 'https://music.apple.com/us/album/entera-consagraci%C3%B3n/1789990550?i=1789990553',
    blurb:
      'A prayer of surrender dressed in warm indie textures — for the slow work of giving every part back to God.',
  },
  {
    title: 'Es Temporal',
    url: 'https://www.youtube.com/watch?v=bjuo7RbqzUU',
    videoId: 'bjuo7RbqzUU',
    apple: 'https://music.apple.com/us/album/es-temporal/1789990550?i=1789990551',
    blurb:
      'A reminder that the present weight is not the final word: everything temporary points past itself.',
  },
  {
    title: 'Infinito Amor (A Través Del Universo)',
    url: 'https://www.youtube.com/watch?v=piyRq1vfOHY',
    videoId: 'piyRq1vfOHY',
    apple:
      'https://music.apple.com/us/album/infinito-amor-a-trav%C3%A9s-del-universo/1789990550?i=1789990552',
    blurb:
      'Cosmic language for a very personal hope: the love of God stretching farther than imagination can travel.',
  },
  {
    title: 'Dimensiones',
    url: 'https://www.youtube.com/watch?v=ROmXgqsGSpY',
    videoId: 'ROmXgqsGSpY',
    apple: 'https://music.apple.com/us/album/dimensiones/1789990550?i=1789990554',
    blurb:
      'A spacious track about faith that reaches beyond the flat edges of what we can measure or explain.',
  },
  {
    title: 'Pasaporte Temporal',
    url: 'https://www.youtube.com/watch?v=5bjlwFPVWKo',
    videoId: '5bjlwFPVWKo',
    apple: 'https://music.apple.com/us/album/pasaporte-temporal/1789990550?i=1789990555',
    blurb: 'A pilgrim song — carrying the tension of living here, but not belonging only here.',
  },
  {
    title: 'Dios Con Nosotros Es',
    url: 'https://www.youtube.com/watch?v=fc9fMb2zi68',
    videoId: 'fc9fMb2zi68',
    apple:
      'https://music.apple.com/us/album/dios-con-nosotros-es-feat-armando-sosa-alejandra-enr%C3%ADquez/1719114728?i=1719114729',
    blurb: 'A collaborative Christmas release celebrating Emmanuel — God near, God with us.',
  },
  {
    title: '¡Ha Nacido El Rey!',
    url: 'https://www.youtube.com/watch?v=OmX1asiDrVo',
    videoId: 'OmX1asiDrVo',
    blurb: 'A bright Spanish Christmas song announcing the joy and arrival of the King.',
  },
  {
    title: 'Día a día',
    url: 'https://www.youtube.com/watch?v=91RiiAn8HKg',
    videoId: '91RiiAn8HKg',
    blurb: 'A daily-faith song for ordinary obedience, ordinary grace, and ordinary dependence.',
  },
  {
    title: 'La Red',
    url: 'https://www.youtube.com/watch?v=vhTkrFQX95U',
    videoId: 'vhTkrFQX95U',
    blurb:
      'An early Inconforme track about the nets that catch us — and the grace that calls us out.',
  },
  {
    title: 'Me Basta Tu Gracia',
    url: 'https://www.youtube.com/watch?v=m6iqX5jFT5M',
    videoId: 'm6iqX5jFT5M',
    blurb: 'A simple confession: grace is not a supplement. It is enough.',
  },
];

const spotifySearch = (title: string) =>
  `https://open.spotify.com/search/${encodeURIComponent(`${title} Inconforme`)}`;
---

<section id="music" class="bg-pink-100">
  <div class="wrapper flex flex-col gap-10 py-20 md:py-24">
    <h2 class="mt-0 font-grotesque text-4xl font-bold tracking-tight text-accent">Music</h2>
    <p class="mb-0 max-w-2xl text-lg text-gray-700/70 md:text-xl">
      I release indie Christian music in Spanish under the name <strong>Inconforme</strong> — songs about
      surrender, hope, and learning to live like this world is not the whole story.
    </p>

    <div class="grid gap-8 md:grid-cols-2">
      {
        songs.map((song) => (
          <article class="group overflow-hidden border-b-2 border-pink-500/10 py-6 ring-accent/5 transition duration-200">
            {/* <a
              href={song.url}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={`Listen to ${song.title} on YouTube`}
            >
              <img
                src={`https://i.ytimg.com/vi/${song.videoId}/hqdefault.jpg`}
                alt=""
                loading="lazy"
                class="h-48 w-full object-cover sm:h-full sm:min-h-40"
              />
            </a> */}
            <div class="flex h-full flex-col gap-2">
              <h3 class="mt-0 mb-2 text-lg leading-tight font-black">
                <a
                  href={song.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-gray-800/90 group-hover:text-accent"
                >
                  {song.title}
                </a>
              </h3>
              <div class="[&>a]:p-1/2 -mt-2 mb-2 flex gap-1 [&>a]:text-gray-500/50 [&>a]:transition-colors [&>a]:duration-200 [&>a]:hover:text-accent">
                <a href={song.url} target="_blank" rel="noopener noreferrer">
                  <YouTubeIcon class="text-lg" />
                </a>
                <a href={spotifySearch(song.title)} target="_blank" rel="noopener noreferrer">
                  <SpotifyIcon class="text-lg" />
                </a>
                <a href={song.apple} target="_blank" rel="noopener noreferrer">
                  <AppleMusicIcon class="text-lg" />
                </a>
              </div>
              <p class="mb-4 text-sm leading-6 text-gray-600">{song.blurb}</p>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
