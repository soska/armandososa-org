---
import type { TimelineEntry, TimelineSubRole } from '../data/timeline';
import { PlusIcon, ExternalLinkIcon } from '@lucide/astro';

interface Props {
  item: TimelineEntry | TimelineSubRole;
  odd?: boolean;
  defaultOpen?: boolean;
  // nested?: boolean;
}

const { item, odd = false, defaultOpen = false } = Astro.props;
const nested = false; // we will remove this soon
const organization = 'organization' in item ? item.organization : undefined;
const location = 'location' in item ? item.location : undefined;
const type = 'type' in item ? item.type : undefined;
const links = item.links ?? [];
const screenshots = item.screenshots ?? [];
const hasMore = links.length > 0 || screenshots.length > 0;
const detailsId = `timeline-more-${item.startDate}-${item.title}`
  .toLowerCase()
  .replace(/[^a-z0-9]+/g, '-')
  .replace(/(^-|-$)/g, '');

const formatDate = (date: string) => {
  if (date === 'present') return 'Present';

  const [year, month] = date.split('-');
  if (!month) return year;

  return new Date(Number(year), Number(month) - 1).toLocaleDateString('en-US', {
    // month: 'short',
    year: 'numeric',
  });
};
---

<li class:list={['grid gap-0 md:grid-cols-2']}>
  <article
    class:list={[
      'timeline-item group relative flex flex-col gap-1 border-l-4 border-accent/20 py-8 pl-4 md:py-4',
      odd
        ? 'col-start-2 md:ml-[-4px] md:pl-6'
        : 'col-start-1 md:items-end md:border-r-4 md:border-l-0 md:pr-6',
    ]}
  >
    <p class="text-md m-0 text-muted md:mt-[-16px]">
      <time datetime={item.startDate}>{formatDate(item.startDate)}</time>
      {' – '}
      <time datetime={item.endDate === 'present' ? undefined : item.endDate}
        >{formatDate(item.endDate)}</time
      >
      {type ? <span> · {type}</span> : null}
      <!-- timeline circle -->
    </p>

    <div
      aria-hidden="true"
      class:list={[
        'absolute top-[16px] left-[-16px] mt-[-16px] size-[28px] rounded-full border-4 border-white bg-yellow-100 shadow-sm transition-all duration-300 group-hover:bg-yellow-300 group-hover:shadow-md',
        odd ? '' : 'md:right-[-16px] md:left-auto',
      ]}
    >
    </div>

    <h3 class="m-0 text-xl font-bold text-text">
      {item.title}{organization ? <span> · {organization}</span> : null}
    </h3>

    {location ? <p class="m-0 text-sm text-muted">{location}</p> : null}
    {
      hasMore ? (
        <div
          class:list={['timeline-details mt-1', odd ? 'md:text-left' : 'md:text-right']}
          data-expanded={defaultOpen ? 'true' : 'false'}
        >
          {item.description ? (
            <p
              class:list={[
                'timeline-description timeline-description--clamped m-0 text-text/80',
                odd ? 'md:text-left' : 'md:text-right',
              ]}
            >
              {item.description}
            </p>
          ) : null}

          <div class="timeline-more-content" id={detailsId}>
            <div>
              {links.length ? (
                <ul
                  class:list={[
                    'flex list-none flex-row flex-wrap gap-x-4 gap-y-2 p-0',
                    odd ? 'md:justify-start' : 'md:justify-end',
                  ]}
                >
                  {links.map((link) => (
                    <li class="m-0 inline-flex items-center gap-1 p-0">
                      <a
                        class="inline-flex items-center gap-1"
                        href={link.url}
                        target="_blank"
                        rel="noreferrer"
                      >
                        {link.label}
                        <ExternalLinkIcon class="size-3" />
                      </a>
                    </li>
                  ))}
                </ul>
              ) : null}

              {screenshots.length ? (
                <div>
                  <h4 class="m-0 mb-2 text-sm font-bold text-text">Screenshots</h4>
                  <div class="flex flex-wrap gap-2">
                    {screenshots.map((screenshot) => (
                      <button
                        class="size-16 overflow-hidden rounded-xl border-2 border-white bg-yellow-100 p-0 shadow-sm transition hover:scale-105 hover:shadow-md focus:ring-2 focus:ring-accent focus:outline-none"
                        type="button"
                        data-timeline-lightbox
                        data-src={screenshot.src}
                        data-alt={screenshot.alt}
                        aria-label={`Open screenshot: ${screenshot.alt}`}
                      >
                        <img
                          class="h-full w-full object-cover"
                          src={screenshot.src}
                          alt={screenshot.alt}
                          loading="lazy"
                        />
                      </button>
                    ))}
                  </div>
                </div>
              ) : null}
            </div>
          </div>

          <button
            class="timeline-more-label inline-flex cursor-pointer items-center gap-1 rounded-full border border-gray-400 bg-transparent px-3 py-1 text-sm font-bold text-gray-700 opacity-50 transition-all duration-150 hover:bg-yellow-200 hover:opacity-100"
            type="button"
            data-timeline-details-toggle
            aria-controls={detailsId}
          >
            <PlusIcon class="size-4" /> read more
          </button>
        </div>
      ) : item.description ? (
        <p class:list={['m-0 text-text/80', odd ? 'md:text-left' : 'md:text-right']}>
          {item.description}
        </p>
      ) : null
    }

    <!-- {
      'subRoles' in item && item.subRoles?.length ? (
        <ul class="mt-3 list-none border-l border-accent/20 pl-4">
          {item.subRoles.map((subRole) => (
            <Astro.self item={subRole} nested />
          ))}
        </ul>
      ) : null
    } -->
  </article>
</li>

<style>
  .timeline-description--clamped {
    max-height: 3.5em;
    overflow: hidden;
    transition:
      max-height 320ms ease,
      mask-image 320ms ease;
    -webkit-mask-image: linear-gradient(to bottom, black 55%, transparent 100%);
    mask-image: linear-gradient(to bottom, black 55%, transparent 100%);
  }

  .timeline-more-content {
    max-height: 0;
    opacity: 0;
    overflow: hidden;
    transform: translateY(-0.25rem);
    transition:
      max-height 320ms ease,
      opacity 240ms ease,
      transform 320ms ease;
  }

  .timeline-details[data-expanded='true'] .timeline-description--clamped {
    max-height: 18rem;
    -webkit-mask-image: linear-gradient(to bottom, black 100%, black 100%);
    mask-image: linear-gradient(to bottom, black 100%, black 100%);
  }

  .timeline-details[data-expanded='true'] .timeline-more-content {
    max-height: 28rem;
    opacity: 1;
    transform: translateY(0);
  }

  .timeline-details[data-expanded='true'] .timeline-more-label {
    display: none;
  }
</style>

<script>
  const win = window as Window & { __timelineLightboxReady?: boolean };

  if (!win.__timelineLightboxReady) {
    win.__timelineLightboxReady = true;

    const dialog = document.createElement('dialog');
    dialog.className =
      'backdrop:bg-black/75 fixed inset-0 m-auto max-h-[90vh] max-w-[90vw] overflow-visible rounded-3xl border-0 bg-transparent p-0';
    dialog.innerHTML = `
      <button class="absolute -top-4 -right-4 z-10 grid size-9 place-items-center rounded-full bg-white text-xl font-bold text-text shadow-lg" type="button" aria-label="Close screenshot">×</button>
      <img class="max-h-[90vh] max-w-[90vw] rounded-2xl bg-white object-contain shadow-2xl" alt="" />
    `;
    document.body.append(dialog);

    const image = dialog.querySelector('img');
    const closeButton = dialog.querySelector('button');

    document.addEventListener('click', (event) => {
      const button = (event.target as Element).closest<HTMLButtonElement>(
        '[data-timeline-lightbox]'
      );
      if (!button || !image) return;

      image.src = button.dataset.src ?? '';
      image.alt = button.dataset.alt ?? '';
      dialog.showModal();
    });

    document.addEventListener('click', (event) => {
      const toggle = (event.target as Element).closest<HTMLButtonElement>(
        '[data-timeline-details-toggle]'
      );
      if (!toggle) return;

      const details = toggle.closest<HTMLElement>('.timeline-details');
      if (details) details.dataset.expanded = 'true';
    });

    closeButton?.addEventListener('click', () => dialog.close());
    dialog.addEventListener('click', (event) => {
      if (event.target === dialog) dialog.close();
    });
  }
</script>
