<style>
  .head {
    width: 90%;
    height: 90%;
    transform-origin: 50% 58%;
    opacity: 0.8;
    transform: rotate(-1deg);
    transition: transform 0.5s ease-in-out;

    /* mix-blend-mode: overlay; */
  }

  .head-looking-up {
    transform: rotate(4deg);
  }

  .head-looking-down {
    transform: rotate(-4deg);
  }

  #eyebrows {
    animation: lift-eyebrows 4s ease-in-out infinite;
  }

  @keyframes lift-eyebrows {
    0% {
      transform: translateY(0);
    }

    50% {
      transform: translateY(-2%);
    }

    100% {
      transform: translateY(0);
    }
  }

  #eyes {
    transform-origin: 50% 50%;
    animation: blink 6s ease-in-out infinite;
  }

  @keyframes blink {
    0%,
    48%,
    52%,
    100% {
      transform: scaleY(1);
    }
    50% {
      transform: scaleY(0.3);
    }
  }

  /*
  @media (prefers-reduced-motion: no-preference) {
    .head {
      animation: float 4s ease-in-out infinite;
    }

    .floating-head:hover .head {
      animation-duration: 1.6s;
    }
  }

  @keyframes float {
    0%,
    100% {
      transform: translateY(0) rotate(-1deg);
    }

    50% {
      transform: translateY(-3px) rotate(1deg);
    }
  } */
</style>

<script>
  let headPositions: 'up' | 'down' | 'center' = 'center';
  const head = document.getElementById('head') as unknown as SVGElement;

  if (head) {
    function lookUp() {
      head.classList.add('head-looking-up');
    }

    function lookDown() {
      head.classList.add('head-looking-down');
    }

    function resetHead() {
      head.classList.remove('head-looking-up');
      head.classList.remove('head-looking-down');
    }

    document.addEventListener('mousemove', (event) => {
      const { clientY } = event;
      const viewportHeight = window.innerHeight;
      const stop1 = viewportHeight / 3;
      const stop2 = (viewportHeight * 2) / 3;
      // const distance = clientY / viewportHeight;
      console.log({ clientY, stop1, stop2 });
      if (clientY < stop1) {
        console.log('up');
        headPositions = 'up';
      } else if (clientY > stop1 && clientY < stop2) {
        console.log('center');
        headPositions = 'center';
      } else {
        console.log('down');
        headPositions = 'down';
      }
      updateHeadRotation();
    });

    function updateHeadRotation() {
      switch (headPositions) {
        case 'up':
          head.classList.add('head-looking-up');
          break;
        case 'down':
          head.classList.add('head-looking-down');
          break;
        case 'center':
          head.classList.remove('head-looking-up');
          head.classList.remove('head-looking-down');
          break;
      }
    }
  }
</script>
