<style>
  .head {
    position: relative;
    z-index: 1;
    width: 90%;
    height: 90%;
    transform-origin: 50% 58%;
    opacity: 0.8;
    will-change: transform;
  }

  /* The head outline tilts; the face shifts within it for a gaze/parallax effect. */
  #face {
    will-change: transform;
  }

  #eyebrows {
    animation: lift-eyebrows 4s ease-in-out infinite;
  }

  @keyframes lift-eyebrows {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-2%);
    }
  }

  #eyes {
    transform-origin: 50% 50%;
    transform-box: fill-box;
    animation: blink 6s ease-in-out infinite;
  }

  @keyframes blink {
    0%,
    48%,
    52%,
    100% {
      transform: scaleY(1);
    }
    50% {
      transform: scaleY(0.15);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #eyebrows,
    #eyes {
      animation: none;
    }
  }

  .globe {
    border: 1px solid var(--color-gray-100);
    position: absolute;
    bottom: 100%;
    left: -100%;
    background-color: #fff;
    border-radius: 30px;
    padding: 1rem 1.5rem;
    text-align: center;
    box-shadow: 0 4px 6px 0 rgba(0, 0, 0, 0.05);
    z-index: 0;
    /* Hidden by default; tucked behind the head. */
    opacity: 0;
    transform: scale(0.3) translateY(300%) translateX(120%) rotate(45deg);
    transition:
      transform 0.3s ease-in-out,
      opacity 0.3s ease-in-out;
    /* Reveal is instant; hiding lingers before it animates away. */
    transition-delay: 0.3s;
  }

  .floating-head:hover .globe,
  .floating-head:focus-within .globe,
  .globe.show {
    opacity: 1;
    transform: rotate(-5deg);
    transition-delay: 0s;
  }

  @media (prefers-reduced-motion: reduce) {
    .globe {
      transition: none;
    }
  }
</style>

<script>
  const container = document.querySelector<HTMLElement>('.floating-head');
  const head = document.getElementById('head');
  const face = document.getElementById('face');
  const globe = container?.querySelector<HTMLElement>('.globe');

  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // Hover/focus reveal is handled in CSS. Touch needs JS: the first tap reveals
  // the callout (and is swallowed so it doesn't also fire the link), a tap
  // outside dismisses it, and a tap on an already-shown link goes through.
  if (container && globe) {
    container.addEventListener(
      'touchstart',
      (event) => {
        if (!globe.classList.contains('show')) {
          event.preventDefault();
          globe.classList.add('show');
        }
      },
      { passive: false }
    );

    document.addEventListener('touchstart', (event) => {
      if (globe.classList.contains('show') && !container.contains(event.target as Node)) {
        globe.classList.remove('show');
      }
    });
  }

  if (container && head && face && !reduceMotion) {
    // How far the head reacts. Larger = calmer.
    const REACH = 520;

    const clamp = (n: number, min: number, max: number) => Math.min(max, Math.max(min, n));

    // Target and current values, eased toward each other every frame.
    let targetX = 0;
    let targetY = 0;
    let curX = 0;
    let curY = 0;

    function onPointerMove(event: PointerEvent) {
      const rect = container!.getBoundingClientRect();
      const cx = rect.left + rect.width / 2;
      const cy = rect.top + rect.height / 2;
      targetX = clamp((event.clientX - cx) / REACH, -1, 1);
      targetY = clamp((event.clientY - cy) / REACH, -1, 1);
    }

    function recenter() {
      targetX = 0;
      targetY = 0;
    }

    function tick() {
      // Ease toward the target (frame-rate-independent-ish critical damping).
      curX += (targetX - curX) * 0.12;
      curY += (targetY - curY) * 0.12;

      // Head only rotates: clockwise to look up, counter-clockwise to look down.
      const tilt = -curY * 9;
      head!.style.transform = `rotate(${tilt}deg)`;

      // Face features: shift within the head (SVG user units) so the gaze leads.
      const gx = curX * 26;
      const gy = curY * 20;
      face!.style.transform = `translate(${gx}px, ${gy}px)`;

      requestAnimationFrame(tick);
    }

    window.addEventListener('pointermove', onPointerMove, { passive: true });
    document.addEventListener('mouseleave', recenter);
    window.addEventListener('blur', recenter);
    requestAnimationFrame(tick);
  }
</script>
