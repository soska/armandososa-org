---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import MainLayout from '../layouts/MainLayout.astro';
// import Bio from '../components/Bio.astro';
import RoleRotator from '../components/RoleRotator';

const allProjects = await getCollection('projects');

const categoryOrder = ['Open Source', 'Fun Tools'];
const categories = categoryOrder
  .map((category) => ({
    category,
    projects: allProjects
      .filter((project) => project.data.category === category)
      .sort((a, b) => a.data.order - b.data.order),
  }))
  .filter((group) => group.projects.length > 0);

const rendered = new Map(
  await Promise.all(
    allProjects.map(async (project) => [project.id, (await render(project)).Content] as const),
  ),
);
---

<MainLayout title="Armando Sosa">
  <div class="hero">
    <div></div>
    <div>
      <h1 class="home-title">
        <a href="/">Hi! I am Armando Sosa</a>
      </h1>

<div class="bio">
  <div>
    I am <RoleRotator client:load />
  </div>
  <div>
    Guadalajara, Mexico
  </div>
</div>

    </div>
  </div>

  <div class="main-content">
  {
    categories.map(({ category, projects }) => (
      <section>
        <h2>{category}</h2>
        {projects.map((project) => {
          const Description = rendered.get(project.id);
          return (
            <article class="project-card">
              <a href={project.data.url} class="project-title">
                {project.data.title}
              </a>
              {project.data.image && (
                <Image src={project.data.image} alt={project.data.title} />
              )}
              {Description && <Description />}
            </article>
          );
        })}
      </section>
    ))
  }
  </div>
</MainLayout>

<style>
  .hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 20vh;
