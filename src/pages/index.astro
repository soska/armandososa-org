---
import { getCollection } from 'astro:content';
import MainLayout from '../layouts/MainLayout.astro';
import RoleRotator from '../components/RoleRotator';
import Projects from '../components/Projects.astro';
import Socials from '../components/Socials.astro';
import Articles from '../components/Articles.astro';
import Music from '../components/Music.astro';
import GithubActivity from '../components/GithubActivity.astro';
import Timeline from '../components/Timeline.astro';
import About from '../components/About.astro';
import Logo from '../components/Logo.astro';
import HeroStrings from '../components/HeroStrings.astro';
import { timeline } from '../data/timeline';

const allProjects = await getCollection('projects');
---

<MainLayout title="Armando Sosa" nav="sections">
  <!-- home hero section -->
  <div
    data-hero
    class="relative isolate mx-auto flex h-[40vh] max-h-[600px] min-h-[400px] w-full flex-col items-center justify-end overflow-hidden bg-accent text-white"
  >
    <HeroStrings />
    <div class="wrapper flex flex-col py-8">
      <div class="flex flex-row items-end">
        <h1
          class="flex flex-row items-center gap-2 border-b-4 border-white/60 p-4 font-grotesque text-hero leading-none font-bold tracking-tight"
        >
          <span class="block text-white/60 [&>svg]:size-12" aria-hidden="true">
            <Logo />
          </span>
          Armando Sosa
        </h1>
      </div>
      <div class="p-4 font-grotesque text-hero leading-none font-bold">
        <RoleRotator client:load />
      </div>
    </div>
    <Socials />
  </div>

  <Projects projects={allProjects} />
  <About />
  <GithubActivity />
  <Timeline items={timeline} />
  <Articles />
  <Music />
</MainLayout>
