---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import MainLayout from '../layouts/MainLayout.astro';
// import Bio from '../components/Bio.astro';
import RoleRotator from '../components/RoleRotator';
import Thumbnails from '../components/Thumbnails.astro';
import Socials from '../components/Socials.astro';
import { resolveProjectImage } from '../lib/projectImages';

const allProjects = await getCollection('projects');

// const categoryOrder = ['Open Source', 'Fun Tools'];
// const categories = categoryOrder
// .map((category) => ({
//   category,
//   projects: allProjects
//     .filter((project) => project.data.category === category)
//     .sort((a, b) => a.data.order - b.data.order),
// }))
// .filter((group) => group.projects.length > 0);

const rendered = new Map(
  await Promise.all(
    allProjects.map(async (project) => [project.id, (await render(project)).Content] as const)
  )
);
---

<MainLayout title="Armando Sosa">
  <div class="mx-auto flex h-[40vh] w-full flex-col items-center justify-end bg-accent text-white">
    <div class="mx-auto flex w-4xl flex-col py-8">
      <h1 class="border-b-4 border-white/50 p-4 font-grotesque text-7xl font-bold">Armando Sosa</h1>
      <div class="p-4 font-grotesque text-7xl font-bold">
        <RoleRotator client:load />
      </div>
    </div>
    <Socials />
  </div>

  <Thumbnails projects={allProjects} />
</MainLayout>
