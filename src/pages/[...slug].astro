---
import { getCollection, render } from 'astro:content';
import MainLayout from '../layouts/MainLayout.astro';
import { formatPostDate, normalizePostPath, sortPosts } from '../lib/posts';

export async function getStaticPaths() {
  const posts = sortPosts(await getCollection('posts'));

  return posts.map((post, index) => ({
    params: { slug: normalizePostPath(post.data.path, post.id) },
    props: {
      postId: post.id,
      previousId: index === posts.length - 1 ? null : posts[index + 1].id,
      nextId: index === 0 ? null : posts[index - 1].id,
    },
  }));
}

const posts = sortPosts(await getCollection('posts'));
const postById = new Map(posts.map((post) => [post.id, post]));

const { postId, previousId, nextId } = Astro.props;
const post = postById.get(postId);
const previous = previousId ? postById.get(previousId) : null;
const next = nextId ? postById.get(nextId) : null;
const { Content } = await render(post);
---

<MainLayout title={`${post.data.title} | Armando Sosa`}>
  <header class="bg-accent text-white">
    <div class="wrapper py-16 md:py-20">
      <p class="mb-3 text-sm text-white/70 uppercase">{formatPostDate(post.data.date)}</p>
      <h1 class="mt-0 mb-0 font-grotesque text-4xl font-bold md:text-5xl">{post.data.title}</h1>
      {
        post.data.subtitle ? (
          <h2 class="mt-3 mb-0 text-xl font-normal text-white/80">{post.data.subtitle}</h2>
        ) : null
      }
    </div>
  </header>

  <article class="wrapper py-16 md:py-20">
    <Content />
  </article>

  <nav class="wrapper pb-20">
    <hr class="mb-7 border-accent/15" />
    <ul class="flex list-none flex-wrap justify-between gap-6 p-0">
      {
        previous ? (
          <li class="max-w-xs">
            <a href={`/${normalizePostPath(previous.data.path, previous.id)}/`} rel="prev">
              ← {previous.data.title}
            </a>
          </li>
        ) : null
      }

      {
        next ? (
          <li class="ml-auto max-w-xs text-right">
            <a href={`/${normalizePostPath(next.data.path, next.id)}/`} rel="next">
              {next.data.title} →
            </a>
          </li>
        ) : null
      }
    </ul>
  </nav>
</MainLayout>
