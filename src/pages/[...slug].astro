---
import { getCollection, render } from 'astro:content';
import MainLayout from '../layouts/MainLayout.astro';
import { formatPostDate, normalizePostPath, sortPosts } from '../lib/posts';

export async function getStaticPaths() {
  const posts = sortPosts(await getCollection('posts'));

  return posts.map((post, index) => ({
    params: { slug: normalizePostPath(post.data.path, post.id) },
    props: {
      postId: post.id,
      previousId: index === posts.length - 1 ? null : posts[index + 1].id,
      nextId: index === 0 ? null : posts[index - 1].id,
    },
  }));
}

const posts = sortPosts(await getCollection('posts'));
const postById = new Map(posts.map((post) => [post.id, post]));

const { postId, previousId, nextId } = Astro.props;
const post = postById.get(postId);
const previous = previousId ? postById.get(previousId) : null;
const next = nextId ? postById.get(nextId) : null;
const { Content } = await render(post);
---

<MainLayout title={`${post.data.title} | Armando Sosa`}>
  <header class="post-header">
    <h1>{post.data.title}</h1>
    {post.data.subtitle ? <h2>{post.data.subtitle}</h2> : null}
    <p class="date">{formatPostDate(post.data.date)}</p>
  </header>

  <article class="post-content">
    <Content />
  </article>

  <hr />

  <ul class="post-nav">
    {previous ? (
      <li>
        <a href={`/${normalizePostPath(previous.data.path, previous.id)}/`} rel="prev">
          ← {previous.data.title}
        </a>
      </li>
    ) : null}

    {next ? (
      <li>
        <a href={`/${normalizePostPath(next.data.path, next.id)}/`} rel="next">
          {next.data.title} →
        </a>
      </li>
    ) : null}
  </ul>
</MainLayout>

<style>
  .post-header {
    background: var(--accent);
    padding: 1.75rem;
    margin-bottom: 1.75rem;
  }

  .post-header h1 {
    color: #fff;
    margin: 0;
    font-weight: 100;
  }

  .post-header h2 {
    margin: 0.35rem 0;
    color: #808080;
    font-size: 1.2rem;
  }

  .date {
    color: gold;
    text-transform: uppercase;
    font-size: 0.88rem;
    margin: -1.75rem 0 1.75rem;
  }

  hr {
    margin-bottom: 1.75rem;
  }

  .post-nav {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    list-style: none;
    padding: 0;
    gap: 0.75rem;
  }
</style>
