---
import { getCollection } from 'astro:content';
import MainLayout from '../layouts/MainLayout.astro';
import { formatPostListDate, normalizePostPath, sortPosts } from '../lib/posts';

function summaryFromMarkdown(markdown: string) {
  return markdown
    .replace(/```[\s\S]*?```/g, '')
    .replace(/`[^`]*`/g, '')
    .replace(/!\[[^\]]*\]\([^)]*\)/g, '')
    .replace(/\[([^\]]*)\]\([^)]*\)/g, '$1')
    .replace(/[*_>#-]/g, ' ')
    .replace(/\s+/g, ' ')
    .trim()
    .slice(0, 210);
}

const posts = sortPosts(await getCollection('posts'));
---

<MainLayout title="Articles | Armando Sosa" heading="Articles">
  {
    posts.map((post) => {
      const href = `/${normalizePostPath(post.data.path, post.id)}/`;
      const summary = post.data.blurb ?? summaryFromMarkdown(post.body ?? '');

      return (
        <article class="post-preview">
          <h3>
            <a href={href}>{post.data.title}</a>
          </h3>
          <p class="date">{formatPostListDate(post.data.date)}</p>
          <p>{summary}</p>
        </article>
      );
    })
  }
</MainLayout>

<style>
  .post-preview {
    margin-bottom: 5rem;
  }

  .post-preview h3 {
    margin-bottom: 0.4375rem;
    margin-top: 0;
  }

  .post-preview h3 a {
    color: #e17055;
  }

  .date {
    font-size: 0.875rem;
    color: #808080;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    margin-bottom: 0.875rem;
  }
</style>
