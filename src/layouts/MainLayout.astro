---
import { Font } from 'astro:assets';
import '../styles/global.css';
import Footer from '../components/Footer.astro';
import Logo from '../components/Logo.astro';

interface Props {
  title?: string;
  heading?: string;
}

const { title = 'Armando Sosa', heading } = Astro.props;
const pathname = Astro.url.pathname;

const navLinks = [
  ['Home', '/'],
  ['Articles', '/#articles'],
  ['About', '/#about'],
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content="Armando Sosa blog and projects" />
    <Font cssVariable="--font-bricolage-grotesque" preload />
    <link rel="icon" href="/favicon.ico" />
  </head>
  <body>
    <!-- <Logo /> -->
    <div class="bg-gray-800">
      <nav class="wrapper flex justify-start gap-4">
        {
          navLinks.map(([label, href]) => {
            const current = pathname === href;
            return (
              <a
                class:list={[
                  'm-1.5 block px-3 py-2 text-[0.79rem] tracking-[0.04em] uppercase hover:text-accent',
                  current ? 'text-accent' : 'text-gray-300 hover:bg-gray-900 hover:text-gray-200',
                ]}
                href={href}
                aria-current={current ? 'page' : undefined}
              >
                {label}
              </a>
            );
          })
        }
      </nav>
    </div>

    <main>
      {heading ? <h1 class="mt-0 mb-11 text-left text-heading text-accent">{heading}</h1> : null}
      <slot />
    </main>

    <Footer />
  </body>
</html>
